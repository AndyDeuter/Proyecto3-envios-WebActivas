@model Parcia1.Models.Usuario

@{
    ViewData["Title"] = "Eliminar Usuario";
}

<h1>Eliminar Usuario</h1>

<h3>¿Estás seguro que deseas eliminar este usuario?</h3>
<div class="alert alert-warning">
    <strong>Advertencia:</strong> Esta acción no se puede deshacer.
</div>

<div>
    <h4>Datos del Usuario</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Nombre)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Nombre)
        </dd>

        <dt class="col-sm-2">
            Rol
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.RolUsuario.Rol)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.correo)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.correo)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Direccion)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Direccion)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="UsuarioId" />

        <input type="submit" value="Eliminar Definitivamente" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
    </form>
</div>
